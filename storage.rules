rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Images are stored at posts/{userId}/{filename}
    match /posts/{userId}/{fileName} {
      // Public read — matches the public Firestore feed
      allow read: if true;

      // Only the authenticated owner can upload to their folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
